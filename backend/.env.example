# ─── Database ─────────────────────────────────────────────────────────────────
# For local development (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# For production (PostgreSQL / NeonDB):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# MUST be set to a strong random string in production (min 32 chars)
JWT_SECRET=change-me-in-production

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Admin Seed ───────────────────────────────────────────────────────────────
# Used by `npm run seed:admin` to create the admin account.
# Change these before running the seed script in production.
ADMIN_NAME="ApronHanger Admin"
ADMIN_EMAIL=admin@apronhanger.in
ADMIN_PASSWORD=change-me-before-running-seed

# ─── Cloudinary (for CV and document storage) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── CORS (comma-separated list of allowed origins) ───────────────────────────
# In development, leave empty to allow all origins.
# In production, set to exact frontend URLs:
# ALLOWED_ORIGINS=https://admin.apronhanger.in,https://recruiter.apronhanger.in,https://app.apronhanger.in
ALLOWED_ORIGINS=

# ─── Brevo (Transactional Email Service) ──────────────────────────────────────
# Used to send onboarding emails: Approved (with activation code), Rejected, Request More Documents.
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Must be a verified sender in your Brevo account dashboard.
# Verify your domain/email at: https://app.brevo.com/senders
BREVO_SENDER_EMAIL=noreply@apronhanger.in
BREVO_SENDER_NAME=ApronHanger Onboarding Team
